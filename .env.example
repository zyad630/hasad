# Copy to .env and fill all values before starting the server
SECRET_KEY=change-this-to-a-random-50-char-string-use-openssl-rand-base64-50
DEBUG=False
DATABASE_URL=postgresql://hisba_user:strong_password@db:5432/hisba_db
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1
CORS_ALLOWED_ORIGINS=https://yourdomain.com
POSTGRES_PASSWORD=strong_password
OPENAI_API_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
